// Visual Studio Code user settings
//
// For information on how to configure VS Code, see the VS Code documentation:
// https://code.visualstudio.com/docs/configure/settings
//
// To see all of VS Code's default settings, run "Preferences: Open Default
// Settings (JSON)" from the command palette (Cmd ⌘ + Shift ⇧ + P).
{
	// This JSON editor is the primary interface for settings.
	// Can switch to GUI using icon in the top-right corner.
	"workbench.settings.editor": "json",

	// Window
	// ======
	"window.openFoldersInNewWindow": "on",
	"window.autoDetectColorScheme": true,

	// Workbench
	// =========
	"workbench.startupEditor": "none",
	"workbench.editor.empty.hint": "hidden",
	"workbench.editor.labelFormat": "short",
	"workbench.tree.renderIndentGuides": "always",
	// Theme
	"workbench.preferredLightColorTheme": "Catppuccin Latte",
	"workbench.preferredDarkColorTheme": "Catppuccin Mocha",
	"workbench.iconTheme": "catppuccin-mocha",

	// Editor
	// ======
	// Font
	"editor.fontFamily": "'Monaspace Neon', 'Symbols Nerd Font', monospace",
	"editor.fontSize": 14,
	"editor.lineHeight": 1.4,
	"editor.fontLigatures": "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'liga'",
	// Inline suggestions and inlay hints
	"editor.inlineSuggest.fontFamily": "'Monaspace Krypton', monospace",
	"editor.inlayHints.fontFamily": "'Monaspace Krypton', monospace",
	"editor.inlayHints.fontSize": 12,
	"editor.inlayHints.padding": true,
	// Decoration
	"editor.rulers": [72, 80, 88, 120],
	"editor.minimap.enabled": false,
	"editor.guides.bracketPairs": true,
	// Whitespace
	"editor.tabSize": 2,
	"editor.insertSpaces": false,
	"editor.renderWhitespace": "boundary",
	"editor.scrollBeyondLastLine": false,
	// Behaviour
	"editor.accessibilitySupport": "off",
	"editor.wordBasedSuggestions": "off",
	// Auto-closing (see Hammerspoon)
	"editor.autoClosingBrackets": "never",
	"editor.autoClosingQuotes": "never",
	"editor.autoSurround": "never",
	// Clipboard
	"editor.emptySelectionClipboard": false,
	// TextMate
	"editor.tokenColorCustomizations": {
		"textMateRules": [
			{
				"scope": "comment",
				"settings": {
					"fontStyle": ""
				}
			}
		]
	},

	// Diff Editor
	// ===========
	"diffEditor.ignoreTrimWhitespace": false,

	// Debug Console
	// =============
	"debug.console.fontFamily": "'Monaspace Neon', 'Symbols Nerd Font', monospace",
	"debug.console.fontSize": 14,
	"debug.console.lineHeight": 1.4,

	// Files
	// =====
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.autoSave": "onFocusChange",

	// Terminal
	// ========
	// Font
	"terminal.integrated.fontFamily": "'Monaspace Neon', 'Symbols Nerd Font', monospace",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.lineHeight": 1.4,
	"terminal.integrated.fontLigatures.enabled": true,
	"terminal.integrated.fontLigatures.featureSettings": "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'liga'",
	// Whitespace
	"terminal.integrated.tabStopWidth": 2,
	// Text
	"terminal.integrated.drawBoldTextInBrightColors": false,
	// Behaviour
	"terminal.integrated.tabs.location": "left",
	"terminal.integrated.showExitAlert": false,
	"terminal.integrated.enablePersistentSessions": false,
	"terminal.integrated.inheritEnv": false,
	"terminal.integrated.initialHint": false,
	"terminal.integrated.stickyScroll.enabled": false,
	"terminal.external.osxExec": "Ghostty.app",

	// Source control
	// ==============
	"git.confirmSync": false,
	"git.openRepositoryInParentFolders": "always",

	// Languages
	// =========
	// HTML
	"[html]": {
		"editor.linkedEditing": true
	},
	// Vue
	"[vue]": {
		"editor.linkedEditing": true
	},
	// Astro
	"[astro]": {
		"editor.linkedEditing": true
	},

	// Extensions
	// ==========
	// Code Spell Checker
	"cSpell.language": "en-GB,en-US"
}
