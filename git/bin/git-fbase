#!/bin/sh
# Print the oldest original commit that has a fixup/squash/amend commit
# targeting it — the base for `git rebase -i $(git fbase)~`.
git log --format='%h%x09%s' "${1:-HEAD}" | awk -F'\t' '
	{ sha[NR] = $1; subj[NR] = $2 }
	END {
		oldest = 0
		for (i = 1; i <= NR; i++) {
			t = subj[i]
			isfix = 0
			while (t ~ /^(fixup|squash|amend)! /) {
				sub(/^(fixup|squash|amend)! /, "", t)
				isfix = 1
			}
			if (!isfix) continue
			# nearest older commit (newest-first log, so j > i) with matching subject
			for (j = i + 1; j <= NR; j++)
				if (subj[j] == t) { if (j > oldest) oldest = j; break }
		}
		if (oldest) print sha[oldest]
		else { print "no fixup commits found" > "/dev/stderr"; exit 1 }
	}
'
