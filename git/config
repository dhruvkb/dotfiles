# CAUTION: Symlinked file


[alias]
  yeet = reset --hard HEAD
  root = rev-parse --show-toplevel

[commit]
  gpgsign = true

[core]
  excludesfile = ~/dotfiles/git/ignore
  pager = delta


[gpg]
  format = ssh

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[init]
  defaultbranch = main



[pager]
  branch = cat

[pull]
  rebase = false

[rebase]
  autosquash = true

[tag]
  gpgsign = true

