[alias]
	root = rev-parse --show-toplevel
	diff-main = !git diff $(git merge-base HEAD main)..HEAD

[branch]
	sort = -committerdate

[column]
	ui = auto

[commit]
	gpgsign = true

[core]
	excludesfile = ~/dotfiles/git/ignore
	# delta reads its config via libgit2, which does not read `GIT_CONFIG_GLOBAL`,
	# so we point delta to this config file explicitly.
	# TODO: Remove `--config` when dandavison/delta#1113 is closed.
	pager = delta --config ~/dotfiles/git/config

[delta]
	features = catppuccin-mocha
	navigate = true

[diff]
	colorMoved = default

[gpg]
	format = ssh

[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[init]
	defaultbranch = main

[interactive]
	# delta reads its config via libgit2, which does not read `GIT_CONFIG_GLOBAL`,
	# so we point delta to this config file explicitly.
	# TODO: Remove `--config` when dandavison/delta#1113 is closed.
	diffFilter = delta --color-only --config ~/dotfiles/git/config

[merge]
	conflictstyle = zdiff3

[pager]
	branch = cat

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[rebase]
	autosquash = true

[rerere]
	enabled = true

[tag]
	gpgsign = true

[user]
