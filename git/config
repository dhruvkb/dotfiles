	email = dhruv_b@live.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAII57SP4Vf5B6n6SThAEWVWHedM9T/Cj3P3nEPawE4Vlv

[include]
	path = ~/.local/share/dotfiles/git/themes.gitconfig

# All repos are placed in ~/Developer under directories named after the GitHub
# username of their owners. So if you want a separate Git config for an
# organisation, add a block like the following to this file...
#
# [includeIf "gitdir:~/Developer/<org>/"]
#   path = ~/dotfiles/git/<org>.gitconfig
#
# ...and a corresponding `<org>.gitconfig` file as a sibling of this file.
