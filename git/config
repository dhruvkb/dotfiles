[alias]
  root = rev-parse --show-toplevel

[branch]
  sort = -committerdate

[column]
  ui = auto

[commit]
  gpgsign = true

[core]
  excludesfile = ~/dotfiles/git/ignore
  pager = delta

[delta]
  navigate = true

[diff]
  colorMoved = default

[gpg]
  format = ssh

[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign

[init]
  defaultbranch = main

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = diff3

[pager]
  branch = cat

[pull]
  rebase = false

[push]
  autoSetupRemote = true

[rebase]
  autosquash = true

[rerere]
  enabled = true

[tag]
  gpgsign = true

[user]
  name = Dhruv Bhanushali
  email = dhruv_b@live.com
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAII57SP4Vf5B6n6SThAEWVWHedM9T/Cj3P3nEPawE4Vlv

# All repos are placed in ~/Developer under folders whose names
# correspond to the GitHub username of their owners.
[includeIf "gitdir:~/Developer/Finrep-ai/"]
